@page "/camera-settings"
@using GFC.BlazorServer.Services.Camera
@inject INvrConfigurationService ConfigService
@inject NavigationManager Navigation

<div class="settings-container">
    <div class="header-section">
        <h1>
            <i class="bi bi-gear-fill"></i> Camera System Settings
            <NewFeatureBadge BadgeText="NEW" TooltipText="Configure NVR connection settings" CssClass="section" />
        </h1>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-camera-video me-2"></i>NVR Connection Settings</h5>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(StatusMessage))
                    {
                        <div class="alert @(IsSuccess ? "alert-success" : "alert-warning") alert-dismissible fade show" role="alert">
                            <i class="bi @(IsSuccess ? "bi-check-circle" : "bi-exclamation-triangle") me-2"></i>
                            @StatusMessage
                            <button type="button" class="btn-close" @onclick="() => StatusMessage = null"></button>
                        </div>
                    }

                    <EditForm Model="@settings" OnValidSubmit="SaveSettings">
                        <DataAnnotationsValidator />
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold">NVR IP Address</label>
                            <InputText class="form-control" @bind-Value="settings.IpAddress" placeholder="192.168.1.64" />
                            <small class="form-text text-muted">The local network IP address of your NVR/DVR</small>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">RTSP Port</label>
                                <InputNumber class="form-control" @bind-Value="settings.RtspPort" />
                                <small class="form-text text-muted">Usually 554</small>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">HTTP Port</label>
                                <InputNumber class="form-control" @bind-Value="settings.HttpPort" />
                                <small class="form-text text-muted">Usually 80</small>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Username <span class="text-danger">*</span></label>
                            <InputText class="form-control" @bind-Value="settings.Username" placeholder="admin" />
                            <ValidationMessage For="@(() => settings.Username)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Password <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <InputText type="@(ShowPassword ? "text" : "password")" class="form-control" @bind-Value="settings.Password" />
                                <button class="btn btn-outline-secondary" type="button" @onclick="() => ShowPassword = !ShowPassword">
                                    <i class="bi @(ShowPassword ? "bi-eye-slash" : "bi-eye")"></i>
                                </button>
                            </div>
                            <ValidationMessage For="@(() => settings.Password)" />
                        </div>

                        <div class="alert alert-info">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Note:</strong> These credentials will be saved to <code>appsettings.json</code>. 
                            For production deployments, consider using environment variables or Azure Key Vault.
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary" disabled="@IsSaving">
                                @if (IsSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                }
                                <i class="bi bi-save me-2"></i>Save Settings
                            </button>
                            <button type="button" class="btn btn-secondary" @onclick="LoadSettings">
                                <i class="bi bi-arrow-clockwise me-2"></i>Reset
                            </button>
                            <a href="/camera-verification" class="btn btn-success">
                                <i class="bi bi-clipboard-check me-2"></i>Test Connection
                            </a>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h6 class="mb-0"><i class="bi bi-question-circle me-2"></i>Help</h6>
                </div>
                <div class="card-body">
                    <h6>Common Default Credentials:</h6>
                    <ul class="small">
                        <li><strong>Dahua/Lorex:</strong> admin / admin</li>
                        <li><strong>Hikvision:</strong> admin / 12345</li>
                        <li><strong>Amcrest:</strong> admin / admin</li>
                    </ul>
                    
                    <hr />
                    
                    <h6>Finding Your NVR IP:</h6>
                    <p class="small">Check your router's DHCP client list or use the NVR's monitor interface to view network settings.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .settings-container {
        padding: 20px;
    }

    .header-section {
        margin-bottom: 30px;
        padding-bottom: 15px;
        border-bottom: 2px solid #e9ecef;
    }

    .header-section h1 {
        font-size: 2rem;
        font-weight: 600;
        color: #2c3e50;
        margin: 0;
        display: flex;
        align-items: center;
    }

    .header-section h1 i {
        margin-right: 12px;
        color: #667eea;
    }
</style>

@code {
    private NvrSettings settings = new();
    private bool ShowPassword = false;
    private bool IsSaving = false;
    private string StatusMessage = null;
    private bool IsSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadSettings();
    }

    private async Task LoadSettings()
    {
        settings = await ConfigService.GetSettingsAsync();
    }

    private async Task SaveSettings()
    {
        IsSaving = true;
        try
        {
            var success = await ConfigService.SaveSettingsAsync(settings);
            
            if (success)
            {
                StatusMessage = "Settings saved successfully! Restart the application for changes to take effect.";
                IsSuccess = true;
            }
            else
            {
                StatusMessage = "Error saving settings. Please check file permissions.";
                IsSuccess = false;
            }
        }
        catch (Exception ex)
        {
            StatusMessage = $"Error saving settings: {ex.Message}";
            IsSuccess = false;
        }
        finally
        {
            IsSaving = false;
        }
    }

    public class NvrSettings
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "IP Address is required")]
        public string IpAddress { get; set; } = "192.168.1.64";
        
        public int RtspPort { get; set; } = 554;
        public int HttpPort { get; set; } = 80;
        
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Username is required")]
        public string Username { get; set; } = "";
        
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = "";
    }
}
