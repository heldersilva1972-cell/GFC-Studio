@page "/cameras"
@using GFC.BlazorServer.Services.Camera
@inject ICameraVerificationService VerificationService

<div class="camera-viewer-container">
    <div class="header-section">
        <h1><i class="fas fa-video"></i> Live Camera Feeds</h1>
        <div class="status-badge @(IsSystemHealthy ? "healthy" : "warning")">
            @(IsSystemHealthy ? "System Online" : "System Checks Pending")
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="alert alert-info">
                <strong>Phase 1 Implementation:</strong> This is the foundational viewer component.
                Backend verification is actively running.
            </div>
        </div>
    </div>

    <div class="camera-grid">
        <!-- Placeholder for Camera 1 -->
        <div class="camera-feed-card">
            <div class="feed-header">
                <span>Camera 01: Main Entrance</span>
                <span class="badge bg-success">Live</span>
            </div>
            <div class="video-placeholder">
                <div class="spinner-border text-light" role="status"></div>
                <p>Connecting to RTSP Stream...</p>
            </div>
        </div>
    </div>
</div>

@code {
    private bool IsSystemHealthy = false;

    protected override async Task OnInitializedAsync()
    {
        // Simple initial check
        var results = await VerificationService.RunAllVerificationsAsync();
        IsSystemHealthy = results.All(r => r.Success);
    }
}
