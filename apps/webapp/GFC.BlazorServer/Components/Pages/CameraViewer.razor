@page "/cameras"
@using GFC.BlazorServer.Services.Camera
@inject ICameraVerificationService VerificationService

<div class="camera-viewer-container">
    <div class="header-section">
        <h1>
            <i class="fas fa-video"></i> Live Camera Feeds
            <NewFeatureBadge BadgeText="NEW" TooltipText="Phase 1: Camera Viewer Implementation" CssClass="section" />
        </h1>
        <div class="status-badge @(IsSystemHealthy ? "healthy" : "warning")">
            @(IsSystemHealthy ? "System Online" : "System Checks Pending")
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="alert alert-info d-flex align-items-center">
                <i class="bi bi-info-circle me-2"></i>
                <div>
                    <strong>Phase 1 Implementation:</strong> This is the foundational viewer component.
                    Backend verification is actively running. Full streaming capabilities will be added in Phase 2.
                </div>
            </div>
        </div>
    </div>

    <div class="camera-grid">
        <!-- Placeholder for Camera 1 -->
        <div class="camera-feed-card">
            <div class="feed-header">
                <span><i class="bi bi-camera-video-fill me-2"></i>Camera 01: Main Entrance</span>
                <span class="badge bg-success">
                    <i class="bi bi-circle-fill pulse-dot me-1"></i>Live
                </span>
            </div>
            <div class="video-placeholder">
                <div class="spinner-border text-light" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-3">Connecting to RTSP Stream...</p>
                <small class="text-muted">192.168.1.64:554</small>
            </div>
            <div class="feed-footer">
                <small class="text-muted">
                    <i class="bi bi-clock me-1"></i>Last updated: @DateTime.Now.ToString("HH:mm:ss")
                </small>
            </div>
        </div>
    </div>
</div>

<style>
    .camera-viewer-container {
        padding: 20px;
    }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 15px;
        border-bottom: 2px solid #e9ecef;
    }

    .header-section h1 {
        font-size: 2rem;
        font-weight: 600;
        color: #2c3e50;
        margin: 0;
        display: flex;
        align-items: center;
    }

    .header-section h1 i {
        margin-right: 12px;
        color: #667eea;
    }

    .status-badge {
        padding: 8px 16px;
        border-radius: 20px;
        font-weight: 600;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-badge.healthy {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        box-shadow: 0 4px 6px rgba(102, 126, 234, 0.3);
    }

    .status-badge.warning {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
        box-shadow: 0 4px 6px rgba(240, 147, 251, 0.3);
    }

    .camera-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
        gap: 24px;
        margin-top: 20px;
    }

    .camera-feed-card {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .camera-feed-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 12px rgba(0, 0, 0, 0.15);
    }

    .feed-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 12px 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
    }

    .feed-header .badge {
        display: flex;
        align-items: center;
    }

    .pulse-dot {
        animation: pulse 2s ease-in-out infinite;
    }

    @@keyframes pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }

    .video-placeholder {
        aspect-ratio: 16 / 9;
        background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        color: white;
    }

    .video-placeholder p {
        margin: 0;
        font-size: 1.1rem;
    }

    .feed-footer {
        padding: 10px 16px;
        background: #f8f9fa;
        border-top: 1px solid #e9ecef;
    }
</style>

@code {
    private bool IsSystemHealthy = false;

    protected override async Task OnInitializedAsync()
    {
        // Simple initial check
        var results = await VerificationService.RunAllVerificationsAsync();
        IsSystemHealthy = results.All(r => r.Success);
    }
}
