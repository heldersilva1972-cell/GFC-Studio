<!-- [NEW] -->
@page "/camera-verification"
@using GFC.Core.Models
@using GFC.BlazorServer.Services.Camera
@using System.Text
@inject ICameraVerificationService VerificationService
@inject IJSRuntime JSRuntime

<div class="container mt-4">
    <div class="card bg-dark text-white shadow-lg border-primary">
        <div class="card-header border-primary bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0"><i class="fas fa-shield-alt mr-2"></i> Camera System Pre-Implementation Verification</h3>
            <span class="badge badge-light">PHASE 0</span>
        </div>
        <div class="card-body">
            @if (_isLoading)
            {
                <div class="text-center my-5">
                    <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                        <span class="sr-only">Loading...</span>
                    </div>
                    <p class="mt-3 text-primary font-weight-bold">Running verification tests, please wait...</p>
                    <p class="text-muted small">Checking hardware, network, and security requirements...</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dark table-hover border-secondary">
                        <thead class="bg-secondary text-white">
                            <tr>
                                <th style="width: 45%;">Test Description</th>
                                <th style="width: 15%;" class="text-center">Status</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in _results)
                            {
                                <tr>
                                    <td class="align-middle font-weight-bold">@result.TestName</td>
                                    <td class="text-center align-middle">
                                        @if (result.Success)
                                        {
                                            <span class="badge badge-success px-3 py-2"><i class="fas fa-check-circle mr-1"></i> PASS</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-danger px-3 py-2"><i class="fas fa-times-circle mr-1"></i> FAIL</span>
                                        }
                                    </td>
                                    <td class="align-middle text-info small">@result.Message</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="mt-4 p-3 bg-secondary rounded d-flex justify-content-between align-items-center">
                    <div>
                        <span class="text-white-50">Overall Status:</span>
                        @if (_results.All(r => r.Success))
                        {
                            <span class="text-success font-weight-bold ml-2">✅ READY TO PROCEED</span>
                        }
                        else
                        {
                            <span class="text-danger font-weight-bold ml-2">❌ ISSUES DETECTED</span>
                        }
                    </div>
                    <div class="text-end">
                        <button class="btn btn-outline-info mr-2" @onclick="() => OnInitializedAsync()">
                            <i class="fas fa-sync-alt"></i> Re-Run Tests
                        </button>
                        <button class="btn btn-primary" @onclick="ExportReport">
                            <i class="fas fa-download"></i> Export Report
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<VerificationResult> _results = new List<VerificationResult>();
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        _results.Clear();
        _isLoading = true;
        StateHasChanged();

        var allTests = await VerificationService.RunAllVerificationsAsync();
        foreach (var test in allTests)
        {
            _results.Add(test);
            StateHasChanged(); 
            await Task.Delay(400); // Visual delay for dashboard effect
        }
        _isLoading = false;
    }

    private async Task ExportReport()
    {
        var sb = new StringBuilder();
        sb.AppendLine("=================================================");
        sb.AppendLine("GFC CAMERA SYSTEM VERIFICATION REPORT");
        sb.AppendLine("=================================================");
        sb.AppendLine($"Report Date: {DateTime.Now:yyyy-MM-dd HH:mm:ss}");
        sb.AppendLine($"User: System Administrator");
        sb.AppendLine("-------------------------------------------------");
        sb.AppendLine("");

        foreach (var result in _results)
        {
            var status = result.Success ? "[ PASS ]" : "[ FAIL ]";
            sb.AppendLine($"{status,-10} {result.TestName}");
            sb.AppendLine($"           Details: {result.Message}");
            sb.AppendLine("");
        }

        sb.AppendLine("-------------------------------------------------");
        sb.AppendLine($"OVERALL STATUS: {(_results.All(r => r.Success) ? "READY TO PROCEED" : "ISSUES DETECTED")}");
        sb.AppendLine("=================================================");

        var reportContent = sb.ToString();
        var fileName = $"GFC_Camera_Verification_{DateTime.Now:yyyyMMdd_HHmm}.txt";

        var bytes = Encoding.UTF8.GetBytes(reportContent);
        var base64 = Convert.ToBase64String(bytes);
        await JSRuntime.InvokeVoidAsync("downloadFileFromBase64", fileName, base64);
    }
}
