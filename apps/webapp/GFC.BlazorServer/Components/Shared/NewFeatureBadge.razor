@* Visual indicator for new/updated features *@
<span class="new-feature-badge @CssClass" title="@TooltipText">
    @BadgeText
</span>

@code {
    [Parameter] public string BadgeText { get; set; } = "NEW";
    [Parameter] public string TooltipText { get; set; } = "This feature was recently added";
    [Parameter] public string CssClass { get; set; } = "";
}

<style>
    .new-feature-badge {
        display: inline-block;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        font-size: 0.65rem;
        font-weight: 700;
        padding: 2px 6px;
        border-radius: 4px;
        margin-left: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        animation: pulse-glow 2s ease-in-out infinite;
        box-shadow: 0 2px 4px rgba(102, 126, 234, 0.3);
    }

    .new-feature-badge.updated {
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    }

    .new-feature-badge.section {
        font-size: 0.7rem;
        padding: 3px 8px;
        margin-left: 12px;
    }

    @@keyframes pulse-glow {
        0%, 100% {
            box-shadow: 0 2px 4px rgba(102, 126, 234, 0.3);
        }
        50% {
            box-shadow: 0 2px 8px rgba(102, 126, 234, 0.6);
        }
    }
</style>
